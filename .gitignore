# Swift Package Manager
.build/
.swiftpm/

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Editor
.idea/
*.swp
*~

# Archive build artifacts
archive/**/.build/

# Worktrees
.worktrees/

# Claude Code
.claude/
.swiftlint.yml

# MCP client config (machine-local; created per-user to attach clients to pippin mcp-server)
.mcp.json

# Dolt database files (added by bd init)
.dolt/
*.db

# Beads / Dolt files (added by bd init)
.beads-credential-key

# Bead pre-commit hook's spurious root export (only /issues.jsonl — .beads/issues.jsonl stays tracked)
/issues.jsonl

# Transient bd auto-import staging file
.beads/.auto-import-issues.jsonl

# Python bytecode (scripts/lint-detach-blocking.py)
__pycache__/
*.pyc

# Graphify knowledge graph (onboarding map). Track graph.json / graph.html / GRAPH_REPORT.md
# so a fresh checkout starts with the map; ignore machine-local + volatile bits.
graphify-out/.graphify_python
graphify-out/.graphify_root
graphify-out/manifest.json
graphify-out/cost.json
graphify-out/cache/
graphify-out/.rebuild.lock
# Dated pre-rebuild backups of the curated graph — local scratch, not history.
graphify-out/20[0-9][0-9]-[0-9][0-9]-[0-9][0-9]/
